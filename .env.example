# Convex (https://dashboard.convex.dev) — deploy functions and copy deployment URL
NEXT_PUBLIC_CONVEX_URL=

# Clerk (https://dashboard.clerk.com) — App Router + Convex auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk issuer for Convex (same as Frontend API URL, e.g. https://….clerk.accounts.dev).
# Set on the Convex deployment as CLERK_JWT_ISSUER_DOMAIN (preferred) or CLERK_FRONTEND_API_URL.
CLERK_JWT_ISSUER_DOMAIN=
CLERK_FRONTEND_API_URL=

# Admin CMS — set to "true" to enable the /admin route
ADMIN_ENABLED=

# Sentry — browser events use NEXT_PUBLIC_SENTRY_DSN if set, otherwise SENTRY_DSN is exposed
# as a safe public DSN at build time.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional override for non-Vercel environments (defaults to VERCEL_ENV or NODE_ENV).
SENTRY_ENVIRONMENT=
# Optional local override; otherwise release defaults to VERCEL_GIT_COMMIT_SHA or deployment id.
SENTRY_RELEASE=
# Set to "true" to enable Sentry in local development.
SENTRY_ENABLED=
# CI-only source map upload settings.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Resend (https://resend.com) — verified domain required for `from`
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Where inquiry emails are delivered (defaults to info@lulalakesound.com if unset)
CONTACT_TO_EMAIL=
