# Convex (https://dashboard.convex.dev) — deploy functions and copy deployment URL
NEXT_PUBLIC_CONVEX_URL=

# Clerk (https://dashboard.clerk.com) — App Router + Convex auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk issuer for Convex (same as Frontend API URL, e.g. https://….clerk.accounts.dev).
# Set on the Convex deployment as CLERK_JWT_ISSUER_DOMAIN (preferred) or CLERK_FRONTEND_API_URL.
CLERK_JWT_ISSUER_DOMAIN=
CLERK_FRONTEND_API_URL=

# Admin access: Clerk user ids from dashboard → Users (e.g. user_xxx). Set in Vercel/hosting AND Convex dashboard.
# Owner always has access; CLERK_ADMIN_USER_IDS is a comma-separated list of additional admins.
CLERK_STUDIO_OWNER_USER_ID=
CLERK_ADMIN_USER_IDS=

# Resend (https://resend.com) — verified domain required for `from`
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Where inquiry emails are delivered (defaults to info@lulalakesound.com if unset)
CONTACT_TO_EMAIL=
